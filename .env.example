# Copy this file to .env.local and fill in the values
# .env.example — environment variable reference for Nestwork

# ENV
NODE_ENV=development
NEXT_ALLOWED_DEV_ORIGINS=192.168.x.x																												  	# Next.js network URL

# Application
NEXT_PUBLIC_APP_NAME=nestwork-web																															  # nestwork-web
NEXT_PUBLIC_APP_URL=http://localhost:3000																											  # http://localhost:3000

# shadcn/ui preset

SHADCN_PRESET=bcivVNCc																																				  # npx shadcn@latest init --preset bcivVNCc --template next --pointer
